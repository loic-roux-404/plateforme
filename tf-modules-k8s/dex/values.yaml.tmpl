---
config:
  issuer: "https://${dex_hostname}"
  web:
    http: 0.0.0.0:5556
  storage:
    type: kubernetes
    config:
      inCluster: true
  connectors:
  - type: github
    id: github
    name: GitHub
    config:
      clientID: '${github_client_id}'
      clientSecret: '${github_client_secret}'
      loadAllGroups: true
      redirectURI: "https://${dex_hostname}/callback"
      orgs:
        ${dex_github_orgs}
  oauth2:
    skipApprovalScreen: true
  staticClients: ${jsonencode(static_clients)}
 
  # grpc:
  #   tlsCert: /tls/tls.crt
  #   tlsKey: /tls/tls.key
  #  % {~ if length(dex_extra_volume_mounts) > 0

  #   tlsClientCA: ${dex_extra_volume_mounts.0.mountPath}/ca.crt

# volumes: ${jsonencode(concat(dex_extra_volumes, dex_tls_volumes))}
# volumeMounts: ${jsonencode(concat(dex_extra_volume_mounts, dex_tls_volume_mounts))}

grpc:
  enabled: false

ingress:
  enabled: true
  className: "${k8s_ingress_class}"
  annotations:
    cert-manager.io/cluster-issuer: ${cert_manager_cluster_issuer}
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/rewrite-target: /

  hosts:
  - host: ${dex_hostname}
    paths:
      - path: /
        pathType: ImplementationSpecific
  tls:
    - secretName: ${dex_hostname}-tls
      hosts:
        - ${dex_hostname}
