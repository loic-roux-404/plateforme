main:
  config:
    db:
      type: postgresdb
      postgresdb:
        host: "${postgres_host}"
        database: "${postgres_db}"
        user: "${postgres_user}"

  secret:
    db:
      postgresdb:
        password: "${postgres_password}"
    n8n:
      encryption_key: "${n8n_encryption_key}"

  replicaCount: 1
  deploymentStrategy:
    type: Recreate
  persistence:
    enabled: false
    # type: "dynamic"
    # mountPath: "/home/node/.n8n"
    # size: 256Mi
    # storageClass: "local-path"
    # accessModes:
    #   - ReadWriteOnce

valkey:
  enabled: false

scaling:
  enabled: true
  redis:
    host: "${valkey_hostname}"
    port: ${valkey_service_port}
    password: "your-password"  # if set
    db: 0  # optional

ingress:
  enabled: true
  className: "${ingress_class}"
  annotations: ${jsonencode(ingress_annotations)}

  hosts:
    - host: ${n8n_hostname}
      paths:
        - path: /
          pathType: Prefix
  tls:
    - hosts:
        - ${n8n_hostname}
      secretName: n8n-${n8n_hostname}-tls
